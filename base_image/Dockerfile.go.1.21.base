FROM ccr-2y3xupwh-pub.cnc.bj.baidubce.com/swe-agent-dev/jyangballin/swesmith.x86_64:latest

# ===== 设置构建阶段代理（仅下载时生效）=====
ENV http_proxy="http://iJbVyX:mJ8eR9tU6%5Bs@10.251.112.51:8799"
ENV https_proxy="http://iJbVyX:mJ8eR9tU6%5Bs@10.251.112.51:8799"

# ===== 安装系统依赖 =====
RUN set -eux && \
    export DEBIAN_FRONTEND=noninteractive && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        git \
        curl \
        wget \
        unzip \
        bash \
        tzdata \
        ca-certificates \
        make \
        build-essential \
        pkg-config \
        gcc \
        g++ \
        libssl-dev \
        libsqlite3-dev \
        zlib1g-dev \
        libbz2-dev \
        libreadline-dev \
        libffi-dev \
        liblzma-dev \
        libxml2-dev \
        libxmlsec1-dev \
        libncurses5-dev \
        libgdbm-dev \
        libnss3-dev \
        xz-utils \
        file \
        sudo \
        vim \
        net-tools \
        iputils-ping \
        procps \
        && rm -rf /var/lib/apt/lists/*

# ===== 安装 Go 1.21.9 =====
RUN set -eux && \
    wget -q https://go.dev/dl/go1.21.9.linux-amd64.tar.gz && \
    tar -C /usr/local -xzf go1.21.9.linux-amd64.tar.gz && \
    rm go1.21.9.linux-amd64.tar.gz

# ===== 设置 Go 环境变量 =====
ENV GOROOT="/usr/local/go"
ENV GOPATH="/root/go"
ENV PATH="${GOROOT}/bin:${GOPATH}/bin:${PATH}"

# 创建工作目录
RUN mkdir -p /root/go/src /root/go/bin /root/go/pkg

WORKDIR /root/go

# ===== 清理代理设置 =====
ENV http_proxy=""
ENV https_proxy=""

# ===== 验证环境 =====
RUN go version && git --version && gcc --version
