FROM ccr-2y3xupwh-pub.cnc.bj.baidubce.com/swe-agent-dev/jyangballin/swesmith.x86_64:latest

# 代理设置（仅构建阶段有效）
ENV http_proxy="http://iJbVyX:mJ8eR9tU6%5Bs@10.251.112.51:8799" \
    https_proxy="http://iJbVyX:mJ8eR9tU6%5Bs@10.251.112.51:8799" \
    HTTP_PROXY="http://iJbVyX:mJ8eR9tU6%5Bs@10.251.112.51:8799" \
    HTTPS_PROXY="http://iJbVyX:mJ8eR9tU6%5Bs@10.251.112.51:8799" \
    no_proxy="localhost,127.0.0.1,::1,10.0.0.0/8,192.168.0.0/16,172.16.0.0/12,*.lan,.baidu.com,.baidu-int.com,baidu.com,baidu-int.com" \
    NO_PROXY="localhost,127.0.0.1,::1,10.0.0.0/8,192.168.0.0/16,172.16.0.0/12,*.lan,.baidu.com,.baidu-int.com,baidu.com,baidu-int.com"

# ---- 系统依赖 ----
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl wget unzip bash tzdata ca-certificates jq patch \
    build-essential pkg-config cmake make g++ gcc \
    libffi-dev libssl-dev libsqlite3-dev zlib1g-dev libbz2-dev libreadline-dev \
    liblzma-dev libncurses5-dev libncursesw5-dev libxml2-dev libxslt1-dev \
    libjpeg-dev libpng-dev libtiff-dev libfreetype6-dev libwebp-dev \
    libblas-dev liblapack-dev gfortran \
    libcurl4-openssl-dev libzstd-dev liblz4-dev \
    libpq-dev libmysqlclient-dev \
    libexpat1-dev libyaml-dev \
    libaugeas0 libaugeas-dev libkrb5-dev \
    && rm -rf /var/lib/apt/lists/*

# ---- Conda 环境 ----
# 安装Java 8
# 使用 Eclipse Temurin (推荐)


RUN wget -O /tmp/jdk17.tar.gz https://github.com/adoptium/temurin17-binaries/releases/download/jdk-17.0.9%2B9/OpenJDK17U-jdk_x64_linux_hotspot_17.0.9_9.tar.gz && \
    tar -C /usr/local -xzf /tmp/jdk17.tar.gz && \
    rm /tmp/jdk17.tar.gz

# 假设解压后的目录名是 'jdk-17.0.9+9'。请根据实际情况调整。
ENV JAVA_HOME="/usr/local/jdk-17.0.9+9"
ENV PATH="${JAVA_HOME}/bin:${PATH}"
WORKDIR /testbed
# ---- Maven & Gradle ----
ENV MAVEN_VERSION=3.9.6
ENV MAVEN_HOME=/usr/local/maven
ENV PATH="${MAVEN_HOME}/bin:${PATH}"
RUN wget -q https://archive.apache.org/dist/maven/maven-3/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.tar.gz && \
    tar -C /usr/local -xzf apache-maven-${MAVEN_VERSION}-bin.tar.gz && \
    mv /usr/local/apache-maven-${MAVEN_VERSION} ${MAVEN_HOME} && \
    rm apache-maven-${MAVEN_VERSION}-bin.tar.gz

ENV GRADLE_VERSION=8.6
ENV GRADLE_HOME=/usr/local/gradle
ENV PATH="${GRADLE_HOME}/bin:${PATH}"
RUN wget -q https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip && \
    unzip -q gradle-${GRADLE_VERSION}-bin.zip -d /usr/local && \
    mv /usr/local/gradle-${GRADLE_VERSION} ${GRADLE_HOME} && \
    rm gradle-${GRADLE_VERSION}-bin.zip

SHELL ["/bin/bash", "-c"]
RUN conda init --all && conda config --append channels conda-forge && \
    source /opt/miniconda3/etc/profile.d/conda.sh && \
    conda create -n testbed python=3.13 -y && \
    conda activate testbed && \
    conda clean -afy && \
    conda install -c conda-forge -y nodejs=20 && \
    pip install --upgrade pip setuptools wheel claude_agent_sdk && \
    npm install -g @anthropic-ai/claude-code@2.0.36

# ---- 启动时自动激活环境 ----
RUN echo "source /opt/miniconda3/etc/profile.d/conda.sh" >> ~/.bashrc && \
    echo "conda activate testbed" >> ~/.bashrc

RUN mkdir -p ~/.claude && \
    cat > ~/.claude/settings.json << 'EOF' && \
    { \
    echo '{'; \
    echo '  "apiKeyHelper": "~/.claude/anthropic_key.sh",'; \
    echo '  "permissions": {"defaultMode": "bypassPermissions"},'; \
    echo '  "theme": "dark",'; \
    echo '  "env": {'; \
    echo '    "ANTHROPIC_BASE_URL": "http://yy.dbh.baidu-int.com",'; \
    echo '    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": 1,'; \
    echo '    "ANTHROPIC_MODEL": "claude-sonnet-4-5-20250929",'; \
    echo '    "ANTHROPIC_SMALL_FAST_MODEL": "claude-sonnet-4-5-20250929",'; \
    echo '    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-5-20250929",'; \
    echo '    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-sonnet-4-5-20250929",'; \
    echo '    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5-20250929"'; \
    echo '  }'; \
    echo '}'; \
    } >> ~/.claude/settings.json && \
    echo "echo \"sk-C1Ru893CN6LZDNw0PDBnt1Yr0J4YkGBu7YHtbHa52xcVc9Rg\"" > ~/.claude/anthropic_key.sh && \
    chmod +x ~/.claude/anthropic_key.sh

ENV IS_SANDBOX="1"

# ---- 清空代理（避免运行时影响） ----
ENV http_proxy=""
ENV https_proxy=""
ENV HTTP_PROXY=""
ENV HTTPS_PROXY=""

# 默认入口：bash 启动自动进入 testbed 环境
CMD ["/bin/bash", "-l"]


# cd /home/disk1/chenyang46/baidu/personal-code/swe-images/swe-agentic && docker build -f Dockerfile.python.3.6.base -t sweagentic.python.3.6:latest .
# docker run -it --name py311-dev sweagentic.python.3.10:latest /bin/bash
