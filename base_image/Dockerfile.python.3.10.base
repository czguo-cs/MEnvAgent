FROM ccr-2y3xupwh-pub.cnc.bj.baidubce.com/swe-agent-dev/jyangballin/swesmith.x86_64:latest

# 代理设置（仅构建阶段有效）
ENV http_proxy="http://iJbVyX:mJ8eR9tU6%5Bs@10.251.112.51:8799" \
    https_proxy="http://iJbVyX:mJ8eR9tU6%5Bs@10.251.112.51:8799" \
    HTTP_PROXY="http://iJbVyX:mJ8eR9tU6%5Bs@10.251.112.51:8799" \
    HTTPS_PROXY="http://iJbVyX:mJ8eR9tU6%5Bs@10.251.112.51:8799" \
    no_proxy="localhost,127.0.0.1,::1,10.0.0.0/8,192.168.0.0/16,172.16.0.0/12,*.lan,.baidu.com,.baidu-int.com,baidu.com,baidu-int.com" \
    NO_PROXY="localhost,127.0.0.1,::1,10.0.0.0/8,192.168.0.0/16,172.16.0.0/12,*.lan,.baidu.com,.baidu-int.com,baidu.com,baidu-int.com"

# ---- 系统依赖 ----
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl wget unzip bash tzdata ca-certificates jq patch \
    build-essential pkg-config cmake make g++ gcc \
    libffi-dev libssl-dev libsqlite3-dev zlib1g-dev libbz2-dev libreadline-dev \
    liblzma-dev libncurses5-dev libncursesw5-dev libxml2-dev libxslt1-dev \
    libjpeg-dev libpng-dev libtiff-dev libfreetype6-dev libwebp-dev \
    libblas-dev liblapack-dev gfortran \
    libcurl4-openssl-dev libzstd-dev liblz4-dev \
    libpq-dev libmysqlclient-dev \
    libexpat1-dev libyaml-dev \
    libaugeas0 libaugeas-dev libkrb5-dev \
    && rm -rf /var/lib/apt/lists/*

# ---- Conda 环境 ----
SHELL ["/bin/bash", "-c"]

RUN conda init --all && conda config --append channels conda-forge && \
    source /opt/miniconda3/etc/profile.d/conda.sh && \
    conda create -n testbed python=3.10 -y && \
    conda activate testbed && \
    pip install --upgrade pip setuptools wheel && \
    conda clean -afy

# ---- 启动时自动激活环境 ----
RUN echo "source /opt/miniconda3/etc/profile.d/conda.sh" >> ~/.bashrc && \
    echo "conda activate testbed" >> ~/.bashrc

# ---- 清空代理（避免运行时影响） ----
ENV http_proxy=""
ENV https_proxy=""
ENV HTTP_PROXY=""
ENV HTTPS_PROXY=""

# 默认入口：bash 启动自动进入 testbed 环境
CMD ["/bin/bash", "-l"]


